-- SEMWOK HUB: FULL UNINTERRUPTED TOGGLES (V42)
-- ==========================================
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Remove old GUI to prevent stacking on re-execute
if game.CoreGui:FindFirstChild("SemWok_TwoFrames_Hub") then
    game.CoreGui.SemWok_TwoFrames_Hub:Destroy()
end

local SG = Instance.new("ScreenGui", game.CoreGui)
SG.Name = "SemWok_TwoFrames_Hub"
SG.ResetOnSpawn = false

-- ==========================================
-- NOCLIP SYSTEM LOGIC
-- ==========================================
_G.NoclipActive = false
local NoclipConnection = nil

local function noclipAction()
    if LP.Character then
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end
end

local function ToggleNoclip(state)
    _G.NoclipActive = state
    if _G.NoclipActive then
        NoclipConnection = RunService.Stepped:Connect(noclipAction)
    else
        if NoclipConnection then
            NoclipConnection:Disconnect()
            NoclipConnection = nil
        end
        pcall(function()
            if LP.Character then
                for _, v in pairs(LP.Character:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = true
                    end
                end
            end
        end)
    end
end

LP.CharacterAdded:Connect(function(char)
    if _G.NoclipActive then
        if NoclipConnection then NoclipConnection:Disconnect() end
        NoclipConnection = RunService.Stepped:Connect(noclipAction)
    end
end)

-- ==========================================
-- UNINTERRUPTED SPEED LOGIC (PERPETUAL LOOP)
-- ==========================================
_G.SpeedActive = false
local SpeedConnection = nil

local function ToggleSpeed(state)
    _G.SpeedActive = state
    if _G.SpeedActive then
        if SpeedConnection then SpeedConnection:Disconnect() end
        SpeedConnection = RunService.Heartbeat:Connect(function()
            pcall(function()
                local char = LP.Character
                if char and char:FindFirstChild("Humanoid") then
                    char.Humanoid.WalkSpeed = 100
                end
            end)
        end)
    else
        if SpeedConnection then
            SpeedConnection:Disconnect()
            SpeedConnection = nil
        end
        pcall(function()
            local char = LP.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = 16
            end
        end)
    end
end

LP.CharacterAdded:Connect(function()
    if _G.SpeedActive then
        ToggleSpeed(true)
    end
end)

-- ==========================================
-- GUI CREATOR MASTER FUNCTION (AUTO CLOSED AT START)
-- ==========================================
local function CreateSmartFrame(name, pos, targetSize, titleTxt)
    -- Frame utama otomatis berukuran tinggi 42 di awal (Tertutup)
    local f = Instance.new("Frame", SG)
    f.Name = name
    f.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    f.BorderSizePixel = 2
    f.BorderColor3 = Color3.fromRGB(60, 60, 60)
    f.Position = pos
    f.Size = UDim2.new(0, targetSize.X.Offset, 0, 42)
    f.Active = true
    f.Draggable = true
    f.ClipsDescendants = true
    
    -- Judul asli menu saat terbuka (Awalnya disembunyikan)
    local tl = Instance.new("TextLabel", f)
    tl.Size = UDim2.new(1, 0, 0, 42)
    tl.RichText = true
    tl.Text = "<b>" .. titleTxt:upper() .. "</b>"
    tl.TextColor3 = Color3.fromRGB(255, 255, 255)
    tl.Font = Enum.Font.SourceSansBold
    tl.TextSize = 18
    tl.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tl.BorderSizePixel = 0
    tl.Visible = false
    
    -- Tombol Segitiga Mini (Warna Hitam Pekat)
    local tg = Instance.new("TextButton", f)
    tg.Size = UDim2.new(0, 30, 0, 30)
    tg.Position = UDim2.new(1, -35, 0, 6)
    tg.Text = "▲"
    tg.TextColor3 = Color3.new(0, 0, 0)
    tg.BackgroundTransparency = 1
    tg.Font = Enum.Font.SourceSansBold
    tg.TextSize = 20
    tg.ZIndex = 5
    
    -- Container isi konten (Awalnya disembunyikan)
    local container = Instance.new("Frame", f)
    container.Name = "C"
    container.Size = UDim2.new(1, 0, 1, -77)
    container.Position = UDim2.new(0, 0, 0, 42)
    container.BackgroundTransparency = 1
    container.Visible = false
    
    -- Watermark saat frame ditutup (Ukuran 22, Kapital, Center Tengah)
    local wmClosed = Instance.new("TextLabel", f)
    wmClosed.Size = UDim2.new(1, 0, 0, 42)
    wmClosed.Position = UDim2.new(0, 0, 0, 0)
    wmClosed.RichText = true
    wmClosed.Text = "<b>YOUTUBE: SEMWOK</b>"
    wmClosed.TextColor3 = Color3.fromRGB(255, 255, 255)
    wmClosed.Font = Enum.Font.SourceSansBold
    wmClosed.TextSize = 22
    wmClosed.BackgroundTransparency = 1
    wmClosed.ZIndex = 4
    wmClosed.TextXAlignment = Enum.TextXAlignment.Center
    wmClosed.Visible = true
    
    local pad = Instance.new("UIPadding", wmClosed)
    pad.PaddingLeft = UDim.new(0, 35)
    pad.PaddingRight = UDim.new(0, 35)
    
    -- Watermark bawah saat frame terbuka (Ukuran 24)
    local wmOpen = Instance.new("TextLabel", f)
    wmOpen.Name = "WM"
    wmOpen.Size = UDim2.new(1, 0, 0, 35)
    wmOpen.Position = UDim2.new(0, 0, 1, -35)
    wmOpen.RichText = true
    wmOpen.Text = "<b>YOUTUBE: SEMWOK</b>"
    wmOpen.TextColor3 = Color3.fromRGB(255, 255, 255)
    wmOpen.Font = Enum.Font.SourceSansBold
    wmOpen.TextSize = 24
    wmOpen.BackgroundColor3 = Color3.new(0, 0, 0)
    wmOpen.BackgroundTransparency = 0.3
    wmOpen.TextXAlignment = Enum.TextXAlignment.Center
    wmOpen.Visible = false
    
    -- Handler Animasi Klik Buka/Tutup
    tg.MouseButton1Click:Connect(function()
        local isOpen = container.Visible
        container.Visible = not isOpen
        tl.Visible = not isOpen
        wmOpen.Visible = not isOpen
        wmClosed.Visible = isOpen
        
        tg.Text = not isOpen and "▼" or "▲"
        f:TweenSize(not isOpen and targetSize or UDim2.new(0, targetSize.X.Offset, 0, 42), "Out", "Quad", 0.15, true)
    end)
    
    return container
end

-- Fungsi pembuat tombol TP Zona / Machine biasa
local function btnTP(parent, txt, y, posCFrame)
    local b = Instance.new("TextButton", parent)
    b.Size, b.Position = UDim2.new(1, -20, 0, 40), UDim2.new(0, 10, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    b.BorderSizePixel = 1
    b.BorderColor3 = Color3.fromRGB(60, 60, 60)
    b.Text, b.TextColor3, b.Font, b.TextSize = "<b>" .. txt .. "</b>", Color3.new(1, 1, 1), Enum.Font.SourceSansBold, 16
    b.RichText = true
    
    b.MouseButton1Click:Connect(function()
        local char = LP.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = posCFrame
        end
    end)
    return b
end


